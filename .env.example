# Database
DATABASE_URL=your_database_url

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_WEB_CLIENT_ID=your_google_web_client_id  # For Android Credential Manager API
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Better Auth
BETTER_AUTH_SECRET=your_secret_key
BETTER_AUTH_URL=https://auth.blazeneuro.com
NEXT_PUBLIC_BETTER_AUTH_URL=https://auth.blazeneuro.com

# CORS
ALLOWED_ORIGIN=https://blazeneuro.com

# Email (Resend)
RESEND_API_KEY=your_resend_api_key

# JWT Keys (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY=your_jwt_private_key
JWT_PUBLIC_KEY=your_jwt_public_key

# Twilio (for phone verification)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid
