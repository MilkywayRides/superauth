# Database
DATABASE_URL=your_database_url

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Better Auth
BETTER_AUTH_SECRET=your_secret_key
BETTER_AUTH_URL=https://auth.blazeneuro.com
NEXT_PUBLIC_BETTER_AUTH_URL=https://auth.blazeneuro.com

# CORS
ALLOWED_ORIGIN=https://blazeneuro.com

# Email (Resend)
RESEND_API_KEY=your_resend_api_key

# JWT Keys (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY=your_jwt_private_key
JWT_PUBLIC_KEY=your_jwt_public_key
